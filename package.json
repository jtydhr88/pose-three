{
  "name": "pose-three",
  "version": "0.1.0",
  "description": "3D human pose editor engine for Three.js — IK/FK posing, CCD solver, pose library, OpenPose / depth / normal map export for AI (ControlNet) reference. Headless engine extracted from free-pose-editor.",
  "type": "module",
  "license": "MIT",
  "author": "Terry Jia",
  "repository": {
    "type": "git",
    "url": "https://github.com/jtydhr88/pose-three"
  },
  "bugs": {
    "url": "https://github.com/jtydhr88/pose-three/issues"
  },
  "keywords": [
    "pose",
    "pose-editor",
    "three",
    "three.js",
    "ik",
    "ccd",
    "skeleton",
    "mixamo",
    "openpose",
    "controlnet",
    "depth-map",
    "normal-map",
    "3d"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "build": "vite build --mode lib",
    "build:lib": "vite build --mode lib",
    "build:playground": "vite build",
    "build:all": "vite build --mode lib && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "three": ">=0.160.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@types/three": "^0.170.0",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^25.0.1",
    "three": "^0.170.0",
    "typescript": "^5.9.0",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^4.1.9"
  }
}
